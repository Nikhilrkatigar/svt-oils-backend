# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
# Local:   mongodb://localhost:27017/svt-oils
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/svt-oils
MONGO_URI=mongodb://localhost:27017/svt-oils

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=svt_oils_super_secret_key_change_in_prod_2026
JWT_EXPIRES_IN=30d

# ─── Admin ────────────────────────────────────────────
# Phone number that gets auto-promoted to admin after password login/register
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=admin1234%

# ─── Frontend URL (for CORS) ──────────────────────────
FRONTEND_URL=http://localhost:3000
